{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://baseball-coaster/schema/frequencies.schema.json",
  "title": "baseball-coaster season+league event-frequency artifact (artifacts/latest/frequencies.json)",
  "$comment": "Generated by bc_pipeline.frequencies (issue #21 g1) from games/**'s events[].outcome.type -- the CLOSED 19-type taxonomy at schemas/game.schema.json $defs.outcome.properties.type.enum. Every counts/rates table always carries all 19 taxonomy keys (0 when a type never occurred for that key) -- never sparse. rate = outcome_type_count / total_plate_appearances_for_that_key (see bc_pipeline.frequencies module docstring).",
  "type": "object",
  "additionalProperties": false,
  "required": ["meta", "league", "by_season"],
  "properties": {
    "meta": { "$ref": "#/$defs/meta" },
    "league": { "$ref": "#/$defs/batting_pitching_block" },
    "by_season": {
      "type": "object",
      "description": "Keyed by season (string, e.g. \"2026\") -- one batting_pitching_block per season.",
      "additionalProperties": { "$ref": "#/$defs/batting_pitching_block" }
    }
  },
  "$defs": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["generated_at", "parser_versions", "games_included", "coverage"],
      "properties": {
        "generated_at": {
          "type": "string",
          "description": "ISO-8601 UTC timestamp this artifact was generated, or the NORMALIZED_TIMESTAMP sentinel (1970-01-01T00:00:00Z) after no-commit-guard normalization."
        },
        "parser_versions": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Distinct meta.parser_version values seen across the aggregated games, sorted -- never silently collapsed to a single assumed value."
        },
        "games_included": {
          "type": "object",
          "additionalProperties": false,
          "required": ["total", "by_season"],
          "properties": {
            "total": { "type": "integer", "minimum": 0 },
            "by_season": {
              "type": "object",
              "description": "Keyed by season (string), games-included count per season.",
              "additionalProperties": { "type": "integer", "minimum": 0 }
            }
          }
        },
        "coverage": {
          "type": "object",
          "additionalProperties": false,
          "description": "Honest-Null coverage block: the LINE-level unparsed rate across the aggregated corpus, from each game's meta.parse.events_count/unparsed_count (never recomputed here).",
          "required": ["total_narrative_lines", "total_unparsed_lines", "unparsed_rate", "note"],
          "properties": {
            "total_narrative_lines": { "type": "integer", "minimum": 0 },
            "total_unparsed_lines": { "type": "integer", "minimum": 0 },
            "unparsed_rate": { "type": "number", "minimum": 0, "maximum": 1 },
            "note": { "type": "string" }
          }
        }
      }
    },
    "batting_pitching_block": {
      "type": "object",
      "additionalProperties": false,
      "required": ["batting", "pitching"],
      "properties": {
        "batting": { "$ref": "#/$defs/side_table" },
        "pitching": { "$ref": "#/$defs/side_table" }
      }
    },
    "side_table": {
      "type": "object",
      "additionalProperties": false,
      "required": ["teams", "players"],
      "properties": {
        "teams": {
          "type": "object",
          "description": "Keyed by team_id.",
          "additionalProperties": { "$ref": "#/$defs/key_entry" }
        },
        "players": {
          "type": "object",
          "description": "Keyed by player_id (the games/** pid).",
          "additionalProperties": { "$ref": "#/$defs/key_entry" }
        }
      }
    },
    "key_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total_plate_appearances", "counts", "rates"],
      "properties": {
        "total_plate_appearances": { "type": "integer", "minimum": 0 },
        "counts": { "$ref": "#/$defs/outcome_counts" },
        "rates": { "$ref": "#/$defs/outcome_rates" }
      }
    },
    "outcome_counts": {
      "type": "object",
      "additionalProperties": false,
      "description": "All 19 taxonomy types always present; 0 when a type never occurred for this key.",
      "required": [
        "single", "double", "triple", "home_run", "walk", "intentional_walk",
        "hit_by_pitch", "strikeout_swinging", "strikeout_looking", "groundout",
        "flyout", "lineout", "popout", "fielders_choice", "reached_on_error",
        "grounded_into_double_play", "sacrifice", "foul_out", "strikeout"
      ],
      "properties": {
        "single": { "type": "integer", "minimum": 0 },
        "double": { "type": "integer", "minimum": 0 },
        "triple": { "type": "integer", "minimum": 0 },
        "home_run": { "type": "integer", "minimum": 0 },
        "walk": { "type": "integer", "minimum": 0 },
        "intentional_walk": { "type": "integer", "minimum": 0 },
        "hit_by_pitch": { "type": "integer", "minimum": 0 },
        "strikeout_swinging": { "type": "integer", "minimum": 0 },
        "strikeout_looking": { "type": "integer", "minimum": 0 },
        "groundout": { "type": "integer", "minimum": 0 },
        "flyout": { "type": "integer", "minimum": 0 },
        "lineout": { "type": "integer", "minimum": 0 },
        "popout": { "type": "integer", "minimum": 0 },
        "fielders_choice": { "type": "integer", "minimum": 0 },
        "reached_on_error": { "type": "integer", "minimum": 0 },
        "grounded_into_double_play": { "type": "integer", "minimum": 0 },
        "sacrifice": { "type": "integer", "minimum": 0 },
        "foul_out": { "type": "integer", "minimum": 0 },
        "strikeout": { "type": "integer", "minimum": 0 }
      }
    },
    "outcome_rates": {
      "type": "object",
      "additionalProperties": false,
      "description": "All 19 taxonomy types always present; rate = count / total_plate_appearances for this key (0.0 in the unreachable-in-practice zero-total case).",
      "required": [
        "single", "double", "triple", "home_run", "walk", "intentional_walk",
        "hit_by_pitch", "strikeout_swinging", "strikeout_looking", "groundout",
        "flyout", "lineout", "popout", "fielders_choice", "reached_on_error",
        "grounded_into_double_play", "sacrifice", "foul_out", "strikeout"
      ],
      "properties": {
        "single": { "type": "number", "minimum": 0, "maximum": 1 },
        "double": { "type": "number", "minimum": 0, "maximum": 1 },
        "triple": { "type": "number", "minimum": 0, "maximum": 1 },
        "home_run": { "type": "number", "minimum": 0, "maximum": 1 },
        "walk": { "type": "number", "minimum": 0, "maximum": 1 },
        "intentional_walk": { "type": "number", "minimum": 0, "maximum": 1 },
        "hit_by_pitch": { "type": "number", "minimum": 0, "maximum": 1 },
        "strikeout_swinging": { "type": "number", "minimum": 0, "maximum": 1 },
        "strikeout_looking": { "type": "number", "minimum": 0, "maximum": 1 },
        "groundout": { "type": "number", "minimum": 0, "maximum": 1 },
        "flyout": { "type": "number", "minimum": 0, "maximum": 1 },
        "lineout": { "type": "number", "minimum": 0, "maximum": 1 },
        "popout": { "type": "number", "minimum": 0, "maximum": 1 },
        "fielders_choice": { "type": "number", "minimum": 0, "maximum": 1 },
        "reached_on_error": { "type": "number", "minimum": 0, "maximum": 1 },
        "grounded_into_double_play": { "type": "number", "minimum": 0, "maximum": 1 },
        "sacrifice": { "type": "number", "minimum": 0, "maximum": 1 },
        "foul_out": { "type": "number", "minimum": 0, "maximum": 1 },
        "strikeout": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    }
  }
}
